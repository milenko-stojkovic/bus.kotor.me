# Example environment for running PHPUnit against MySQL (copy values into your shell or a
# local-only file — do NOT commit real .env.testing.mysql with secrets).
#
# Rule: DB_DATABASE must end with _test so it is never confused with dev/prod.
#
# See: docs/testing-mysql.md

APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bus_kotor_test
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
SESSION_DRIVER=array

BCRYPT_ROUNDS=4
