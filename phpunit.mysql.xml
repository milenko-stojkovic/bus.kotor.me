<?xml version="1.0" encoding="UTF-8"?>
<!--
    Optional PHPUnit config: run the suite against MySQL (not the default SQLite in-memory).

    Prerequisite: a dedicated database whose name ENDS WITH _test (e.g. bus_kotor_test).
    Override any value via environment variables before running PHPUnit (they typically
    take precedence over this file depending on your PHPUnit/Laravel version).

    Example (PowerShell, Laragon):
      $env:DB_DATABASE='bus_kotor_test'
      $env:DB_USERNAME='root'
      $env:DB_PASSWORD=''
      .\vendor\bin\phpunit -c phpunit.mysql.xml

    Or use .env.testing.mysql.example as a reference and export the same variables.

    WARNING: RefreshDatabase will DROP ALL TABLES in the selected database.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="bus_kotor_test"/>
        <env name="DB_USERNAME" value="root"/>
        <env name="DB_PASSWORD" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
