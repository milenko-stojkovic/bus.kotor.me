APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain (must match public URL)
APP_URL=http://localhost
# Kotor: Europe/Podgorica (ljetnje/zimsko računanje automatski). Ostavi prazno za isti default iz config/app.php.
# APP_TIMEZONE=Europe/Podgorica
# Opciono: TZ za operativne termine (control dolasci, admin „next hours“). Podrazumijevano = APP_TIMEZONE.
# RESERVATIONS_OPERATIONS_TIMEZONE=Europe/Podgorica

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production HTTPS: SESSION_SECURE_COOKIE=true
# SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Production: use database or redis — not sync (callbacks / fiscal / email need queue:work)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Separate SMTP credentials for auth/system emails (verification, password reset)
MAIL_NOREPLY_USERNAME=null
MAIL_NOREPLY_PASSWORD=null
MAIL_FROM_NOREPLY_ADDRESS="noreply@kotor.me"
MAIL_FROM_NOREPLY_NAME="No reply - Kotor Bus"

# Payment & fiscalization: fake (local) | real/bankart (production)
BANK_DRIVER=fake
FISCALIZATION_DRIVER=fake
# Fake QA (oba fake): prekidač sync vs queue za pipeline (ProcessReservation… / SendInvoiceEmail… preko QueueMode).
# true  = fake QA sync režim — isti tok ide dispatch_sync; worker nije bitan za taj tok.
# false + QUEUE_CONNECTION=database = fake QA queue režim — PaymentCallbackJob / pipeline na red; potreban queue:work.
# QUEUE_CONNECTION=database samo omogućava red; ne garantuje ga ako je FAKE_PAYMENT_E2E_SYNC=true (ili dispatch_sync negdje drugo).
FAKE_PAYMENT_E2E_SYNC=true
BANKART_API_URL=
BANKART_API_KEY=
BANKART_USERNAME=
BANKART_PASSWORD=
BANKART_SHARED_SECRET=changeme
BANKART_SIGNATURE_ENABLED=true
BANKART_SEND_CUSTOMER=true
BANKART_BILLING_ADDRESS1=
BANKART_BILLING_CITY=
BANKART_BILLING_POSTCODE=
# Lokalni HTTPS (Laragon self-signed): cURL error 60 na fake fiskal URL → false. U produkciji uvek true (izostavi ili true).
# FISCAL_HTTP_VERIFY_SSL=false

# Outbound HTTP (optional; defaults in config/http-outbound.php)
# BANKART_HTTP_CONNECT_TIMEOUT=5
# BANKART_HTTP_TIMEOUT=25
# BANKART_CREATE_SESSION_HTTP_CONNECT_TIMEOUT=
# BANKART_CREATE_SESSION_HTTP_TIMEOUT=
# BANKART_STATUS_INQUIRY_HTTP_CONNECT_TIMEOUT=
# BANKART_STATUS_INQUIRY_HTTP_TIMEOUT=
# FISCAL_HTTP_CONNECT_TIMEOUT=5
# FISCAL_HTTP_TIMEOUT=25
# FISCAL_DEPOSIT_HTTP_CONNECT_TIMEOUT=
# FISCAL_DEPOSIT_HTTP_TIMEOUT=
# FISCAL_RECEIPT_HTTP_CONNECT_TIMEOUT=
# FISCAL_RECEIPT_HTTP_TIMEOUT=

# Log WARNING payment_pending_too_long kada je temp_data pending duže od (minuta)
# PAYMENT_STALE_PENDING_WARN_AFTER_MINUTES=12

# Fiskalni servis (kad je FISCALIZATION_DRIVER=real, koristi se FISCAL_API_URL + FISCAL_API_TOKEN)
# Base URL bez /api (servis endpointi su /api/efiscal/*)
FISCAL_API_URL=http://localhost
FISCAL_API_TOKEN=fake-token
FISCAL_ENU_IDENTIFIER=
FISCAL_USER_CODE=
FISCAL_USER_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
